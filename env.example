# FlareSolverr HTTP base (no trailing path). This app only calls POST {FLARE_BASE_URL}/v1
# If you reverse-proxy Flare to port 80, use http://your-host  (and no :8191)
FLARE_BASE_URL=http://127.0.0.1:8191



# This Express app
APP_PORT=3040
# Default cap for a single request.get in ms
FLARE_MAX_TIMEOUT_MS=120000
# Optional default outbound proxy for Flare request.get when callers do not pass proxy.url.
# Example: FLARE_PROXY_URL=http://user:pass@proxy-host:proxy-port
# FLARE_PROXY_URL=
# Seconds to wait after challenge solve (0 = omit; use 1 if parsed HTML is empty)
# FLARE_WAIT_AFTER_SECONDS=0
# 1 = Flare `disableMedia` when not set per-request
# FLARE_DISABLE_MEDIA=1
# In-memory cache for successful phone-search JSON (0 = disabled)
# PHONE_CACHE_TTL_MS=86400000
# PHONE_CACHE_MAX=500
# Persistent cache / timeout settings for public-source enrichment requests
# ENRICHMENT_CACHE_MAX=5000
# ENRICHMENT_HTTP_TIMEOUT_MS=20000
# External people-finder / source comparison settings
# ENABLE_EXTERNAL_PEOPLE_SOURCES=1
# EXTERNAL_SOURCE_TIMEOUT_MS=45000
# EXTERNAL_SOURCE_CACHE_TTL_MS=604800000
# EXTERNAL_SOURCE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# EXTERNAL_SOURCE_ACCEPT_LANGUAGE=en-US,en;q=0.9
# Optional contact / user-agent hint for public OSM endpoints
# OSINT_CONTACT_EMAIL=you@example.com
# ENRICHMENT_USER_AGENT=usphonebook-flare-app/1.0 (you@example.com)
# Census geocoder settings (public/free; no API key required)
# CENSUS_CACHE_TTL_MS=2592000000
# CENSUS_BENCHMARK=Public_AR_Current
# CENSUS_VINTAGE=Current_Current
# Overpass nearby-place settings (public/free; cached + rate-limited)
# OVERPASS_CACHE_TTL_MS=2592000000
# OVERPASS_RADIUS_METERS=500
# OVERPASS_MAX_PLACES=8
# OVERPASS_MIN_INTERVAL_MS=1100
# OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
# Generic county assessor source configuration. JSON array of per-county search templates.
# Example:
# ASSESSOR_SOURCES_JSON=[{"key":"cumberland-me","name":"Cumberland County Assessor","state":"ME","countyIncludes":["cumberland"],"searchUrlTemplate":"https://county.example/search?address={encodedAddress}","useFlare":false}]
# Maine county references are built in automatically from census county matches and point to county/municipal property-resource directories.
# ASSESSOR_CACHE_TTL_MS=1209600000
# ASSESSOR_TIMEOUT_MS=25000
# Comma-separated query/body param names to skip cache, e.g. ?nocache=1
# PHONE_CACHE_BYPASS=bypass,nocache,skipCache
# Reuse a single Flare session (faster than cold browser each time; set 0 to disable)
# FLARE_REUSE_SESSION=1
# Optional session rotation for request.get (Flare API session_ttl_minutes)
# FLARE_SESSION_TTL_MINUTES=60

# Optional: load .env from elsewhere
# DOTENV_PATH=/opt/usphonebook-flare-app/.env



## Korys ENV
FLARE_BASE_URL=http://localhost:32768

# Express app port.
APP_PORT=3040

# Optional tuning defaults.
FLARE_MAX_TIMEOUT_MS=120000
# FLARE_WAIT_AFTER_SECONDS=0
# FLARE_DISABLE_MEDIA=1
# PHONE_CACHE_TTL_MS=86400000
# PHONE_CACHE_MAX=500
# PHONE_CACHE_BYPASS=bypass,nocache,skipCache
# FLARE_REUSE_SESSION=1
# FLARE_SESSION_TTL_MINUTES=60
# DOTENV_PATH=C:\path\to\.env